{
  "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentSize": 2,
    "include": [
      "**/*.{js,jsx,ts,tsx,json,md,yml,yaml}"
    ],
    "exclude": [
      "node_modules/**"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    },
    "include": [
      "**/*.{js,jsx,ts,tsx}"
    ],
    "exclude": [
      "node_modules/**"
    ]
  }
}
